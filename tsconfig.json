{
    "compilerOptions": {
        "target": "ES2023",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "docs/.vitepress/**/*.ts", 
        "docs/.vitepress/**/*.vue",
        "docs/**/*.ts",
        "docs/**/*.vue",
        "docs/**/*.md",
    ],
    "vueCompilerOptions": {
        "vitePressExtensions": [ ".md" ],
    }
}